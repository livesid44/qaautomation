@model List<SamplingPolicyViewModel>
@{
    ViewData["Title"] = L["PageTitleSampling"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-funnel me-2 text-primary"></i>@L["SamplingTitle"]</h4>
        <p class="text-muted mb-0">Define how completed AI-audited calls are sampled for human review. Apply a policy to enqueue calls automatically.</p>
    </div>
    <a href="@Url.Action("Create", "Sampling")" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>@L["SamplingCreate"]
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-funnel" style="font-size:3rem"></i>
            <p class="mt-3">No sampling policies defined yet.<br />
            Create one to automatically sample AI-audited calls for human review.</p>
            <a href="@Url.Action("Create", "Sampling")" class="btn btn-primary mt-2">
                <i class="bi bi-plus-circle me-1"></i>Create First Policy
            </a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>@L["LblName"]</th>
                        <th>Call Type Filter</th>
                        <th>Method</th>
                        <th>Sample Value</th>
                        <th>Duration Filter</th>
                        <th>@L["LblStatus"]</th>
                        <th>@L["LblEvaluatedBy"]</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td class="fw-semibold">
                                @p.Name
                                @if (!string.IsNullOrEmpty(p.Description))
                                {
                                    <div class="text-muted small">@p.Description</div>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(p.CallTypeFilter))
                                {
                                    <span class="badge bg-info text-dark">@p.CallTypeFilter</span>
                                }
                                else
                                {
                                    <span class="text-muted small">All call types</span>
                                }
                            </td>
                            <td>
                                @if (p.SamplingMethod == "Percentage")
                                {
                                    <span class="badge bg-primary">Percentage</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Count</span>
                                }
                            </td>
                            <td>
                                @if (p.SamplingMethod == "Percentage")
                                {
                                    <span>@p.SampleValue%</span>
                                }
                                else
                                {
                                    <span>@((int)p.SampleValue) calls</span>
                                }
                            </td>
                            <td class="small text-muted">
                                @if (p.MinDurationSeconds.HasValue || p.MaxDurationSeconds.HasValue)
                                {
                                    @(p.MinDurationSeconds.HasValue ? $"≥{p.MinDurationSeconds}s" : "")
                                    @(p.MinDurationSeconds.HasValue && p.MaxDurationSeconds.HasValue ? " – " : "")
                                    @(p.MaxDurationSeconds.HasValue ? $"≤{p.MaxDurationSeconds}s" : "")
                                }
                                else
                                {
                                    <span>Any duration</span>
                                }
                            </td>
                            <td>
                                @if (p.IsActive)
                                {
                                    <span class="badge bg-success">@L["LblActive"]</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@L["LblInactive"]</span>
                                }
                            </td>
                            <td class="small text-muted">@p.CreatedBy</td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <form method="post" action="@Url.Action("Apply", "Sampling", new { id = p.Id })" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success"
                                                title="Apply policy — sample eligible calls into the review queue"
                                                onclick="return confirm('Apply this sampling policy now? This will add sampled calls to the Human Review queue.')">
                                            <i class="bi bi-play-fill"></i> Apply
                                        </button>
                                    </form>
                                    <a href="@Url.Action("Edit", "Sampling", new { id = p.Id })" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="@Url.Action("Delete", "Sampling", new { id = p.Id })" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Delete this sampling policy?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
