@model TrainingPlanViewModel
@inject QAAutomation.Web.Services.ApiClient ApiClient
@{
    ViewData["Title"] = L["PageTitleTrainingPlans"].Value;
    bool isAdmin = User.IsInRole("Admin");
    bool isTrainer = string.Equals(User.Identity?.Name, Model.TrainerUsername, StringComparison.OrdinalIgnoreCase);
    bool canMarkDone = isAdmin || isTrainer;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-mortarboard me-2 text-primary"></i>@Model.Title</h4>
        <p class="text-muted mb-0">
            Agent: <strong>@Model.AgentName</strong>
            &nbsp;·&nbsp; Trainer: <strong>@Model.TrainerName</strong>
            @if (Model.DueDate.HasValue)
            {
                var overdue = Model.DueDate.Value < DateTime.UtcNow && Model.Status is not "Closed";
                <span class="@(overdue ? "text-danger" : "")">
                    &nbsp;·&nbsp; Due: <strong>@Model.DueDate.Value.ToString("MMM d, yyyy")</strong>
                    @if (overdue) { <i class="bi bi-exclamation-circle"></i> }
                </span>
            }
        </p>
    </div>
    <a href="@Url.Action("Index", "Training")" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>@L["NavTrainingPlans"]
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- Plan body -->
    <div class="col-lg-8">

        <!-- Status + action bar -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body d-flex align-items-center gap-3 flex-wrap">
                @{
                    var (badge, label) = Model.Status switch
                    {
                        "Draft" => ("bg-light text-dark border", "Draft"),
                        "Active" => ("bg-primary", "Active"),
                        "InProgress" => ("bg-info text-dark", "In Progress"),
                        "Completed" => ("bg-warning text-dark", "Completed"),
                        "Closed" => ("bg-success", "Closed"),
                        _ => ("bg-secondary", Model.Status)
                    };
                }
                <span class="badge @badge fs-6 px-3 py-2">@label</span>

                @if (Model.TotalItems > 0)
                {
                    var pct = (int)Math.Round((double)Model.CompletedItems / Model.TotalItems * 100);
                    <div class="d-flex align-items-center gap-2 flex-grow-1">
                        <div class="progress flex-grow-1" style="height:8px">
                            <div class="progress-bar bg-success" style="width:@pct%"></div>
                        </div>
                        <span class="small text-muted fw-semibold">@Model.CompletedItems / @Model.TotalItems items done (@pct%)</span>
                    </div>
                }

                <div class="d-flex gap-2 ms-auto">
                    @if (isAdmin && Model.Status == "Draft")
                    {
                        <a href="@Url.Action("Edit", "Training", new { id = Model.Id })" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                        <form method="post" action="@Url.Action("Activate", "Training", new { id = Model.Id })">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-primary">
                                <i class="bi bi-send me-1"></i>Activate
                            </button>
                        </form>
                    }
                    @if (Model.Status == "Active" && (isAdmin || isTrainer))
                    {
                        <form method="post" action="@Url.Action("Start", "Training", new { id = Model.Id })">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-info">
                                <i class="bi bi-play-fill me-1"></i>Start Training
                            </button>
                        </form>
                    }
                    @if (Model.Status is "InProgress" or "Completed" && isAdmin)
                    {
                        <a href="@Url.Action("Close", "Training", new { id = Model.Id })" class="btn btn-sm btn-success">
                            <i class="bi bi-check2-circle me-1"></i>Close Loop
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Description -->
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold border-0 pt-3">
                    <i class="bi bi-card-text me-1 text-secondary"></i>Description / Context
                </div>
                <div class="card-body small" style="white-space:pre-wrap">@Model.Description</div>
            </div>
        }

        <!-- Plan items -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold border-0 pt-3">
                <i class="bi bi-list-check me-1 text-primary"></i>Observations &amp; Recommendations
            </div>
            <div class="card-body p-0">
                @if (!Model.Items.Any())
                {
                    <div class="p-4 text-muted text-center">No items defined for this plan.</div>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light small">
                            <tr>
                                <th style="width:100px">Type</th>
                                <th style="width:130px">Target Area</th>
                                <th>Content</th>
                                <th style="width:110px">Status</th>
                                @if (canMarkDone && Model.Status == "InProgress") { <th></th> }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items.OrderBy(i => i.Order))
                            {
                                <tr class="@(item.Status == "Done" ? "table-success" : "")">
                                    <td>
                                        @if (item.ItemType == "Recommendation")
                                        {
                                            <span class="badge bg-primary small">Recommendation</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary small">Observation</span>
                                        }
                                    </td>
                                    <td class="small text-muted">@item.TargetArea</td>
                                    <td>
                                        <div>@item.Content</div>
                                        @if (item.Status == "Done" && !string.IsNullOrEmpty(item.CompletionNotes))
                                        {
                                            <div class="small text-success mt-1">
                                                <i class="bi bi-check-circle me-1"></i>@item.CompletionNotes
                                                <span class="text-muted ms-1">(by @item.CompletedBy)</span>
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        @switch (item.Status)
                                        {
                                            case "Done":
                                                <span class="badge bg-success">Done</span>
                                                break;
                                            case "InProgress":
                                                <span class="badge bg-info text-dark">In Progress</span>
                                                break;
                                            default:
                                                <span class="badge bg-light text-dark border">Pending</span>
                                                break;
                                        }
                                    </td>
                                    @if (canMarkDone && Model.Status == "InProgress")
                                    {
                                        <td class="text-end">
                                            @if (item.Status != "Done")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-success"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#completeModal"
                                                        data-planid="@Model.Id"
                                                        data-itemid="@item.Id">
                                                    <i class="bi bi-check2"></i> Done
                                                </button>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        @* ── LLM Training Material ──────────────────────────────────────── *@
        @if (!string.IsNullOrWhiteSpace(Model.LlmTrainingContent))
        {
            <div class="card border-0 shadow-sm mb-4" id="trainingMaterialCard">
                <div class="card-header bg-transparent fw-semibold border-0 pt-3 d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-journal-text me-1 text-primary"></i>Training Material</span>
                    @if (Model.ContentGeneratedAt.HasValue)
                    {
                        <small class="text-muted">Generated @Model.ContentGeneratedAt.Value.ToLocalTime().ToString("MMM d, yyyy HH:mm")</small>
                    }
                </div>
                <div class="card-body">
                    @foreach (var para in (Model.LlmTrainingContent ?? "").Split(new[] { "\n\n", "\r\n\r\n" }, StringSplitOptions.RemoveEmptyEntries))
                    {
                        <p>@para</p>
                    }
                </div>
            </div>
        }

        @* ── MCQ Assessment ────────────────────────────────────────────────── *@
        @if (!string.IsNullOrWhiteSpace(Model.AssessmentJson) && Model.Status is "Completed" or "Closed")
        {
            <div class="card border-0 shadow-sm mb-4" id="assessmentCard">
                <div class="card-header bg-transparent fw-semibold border-0 pt-3">
                    <i class="bi bi-patch-question me-1 text-warning"></i>Knowledge Assessment
                    <span class="badge bg-light text-dark border ms-2 small">Pass mark: @Model.AssessmentPassMark%</span>
                </div>
                <div class="card-body">
                    <div id="assessmentForm">
                        <p class="text-muted small">Please read the training material above, then answer the questions below.</p>
                        <div id="questionList"></div>
                        <div class="d-flex gap-2 mt-3">
                            <button class="btn btn-warning" id="submitAssessmentBtn" onclick="submitAssessment()">
                                <i class="bi bi-send me-1"></i>Submit Answers
                            </button>
                        </div>
                    </div>
                    <div id="assessmentResult" class="d-none"></div>
                </div>
            </div>
        }
    </div>

    <!-- Side panel -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent fw-semibold border-0 pt-3 small">
                <i class="bi bi-info-circle me-1 text-info"></i>Plan Details
            </div>
            <div class="card-body small">
                <dl class="row mb-0">
                    <dt class="col-5 text-muted">Agent</dt>
                    <dd class="col-7">@Model.AgentName</dd>
                    <dt class="col-5 text-muted">Trainer</dt>
                    <dd class="col-7">@Model.TrainerName</dd>
                    <dt class="col-5 text-muted">Created By</dt>
                    <dd class="col-7">@Model.CreatedBy</dd>
                    <dt class="col-5 text-muted">Created</dt>
                    <dd class="col-7">@Model.CreatedAt.ToString("MMM d, yyyy")</dd>
                    @if (Model.DueDate.HasValue)
                    {
                        <dt class="col-5 text-muted">Due Date</dt>
                        <dd class="col-7">@Model.DueDate.Value.ToString("MMM d, yyyy")</dd>
                    }
                    @if (Model.ClosedAt.HasValue)
                    {
                        <dt class="col-5 text-muted">Closed By</dt>
                        <dd class="col-7">@Model.ClosedBy</dd>
                        <dt class="col-5 text-muted">Closed At</dt>
                        <dd class="col-7">@Model.ClosedAt.Value.ToString("MMM d, yyyy")</dd>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.ClosingNotes))
                    {
                        <dt class="col-5 text-muted">Closing Notes</dt>
                        <dd class="col-7" style="white-space:pre-wrap">@Model.ClosingNotes</dd>
                    }
                </dl>
            </div>
        </div>

        @if (Model.EvaluationResultId.HasValue || Model.HumanReviewItemId.HasValue)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent fw-semibold border-0 pt-3 small">
                    <i class="bi bi-link-45deg me-1 text-secondary"></i>Linked Sources
                </div>
                <div class="card-body small">
                    @if (Model.EvaluationResultId.HasValue)
                    {
                        <a href="@Url.Action("Details", "Audit", new { id = Model.EvaluationResultId })" class="btn btn-sm btn-outline-secondary w-100 mb-2" target="_blank">
                            <i class="bi bi-clipboard2-check me-1"></i>View Audit Record #@Model.EvaluationResultId
                        </a>
                    }
                    @if (Model.HumanReviewItemId.HasValue)
                    {
                        <a href="@Url.Action("Review", "HumanReview", new { id = Model.HumanReviewItemId })" class="btn btn-sm btn-outline-secondary w-100" target="_blank">
                            <i class="bi bi-person-check me-1"></i>View Human Review #@Model.HumanReviewItemId
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- Complete Item Modal -->
<div class="modal fade" id="completeModal" tabindex="-1" aria-labelledby="completeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="completeModalLabel"><i class="bi bi-check2-circle me-2"></i>Mark Item as Done</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="completeForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Completion Notes (optional)</label>
                        <textarea name="completionNotes" class="form-control" rows="3"
                                  placeholder="Describe how this item was addressed…"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check2 me-1"></i>Mark Done
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (function () {
        const modal = document.getElementById('completeModal');
        if (!modal) return;
        modal.addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            const planId = btn.getAttribute('data-planid');
            const itemId = btn.getAttribute('data-itemid');
            const form = document.getElementById('completeForm');
            form.action = '@Url.Content("~/Training/CompleteItem/")' + planId + '/' + itemId;
        });
    })();
</script>

@if (!string.IsNullOrWhiteSpace(Model.AssessmentJson) && Model.Status is "Completed" or "Closed")
{
    <script>
        (function () {
            const planId = @Model.Id;
            const passMark = @Model.AssessmentPassMark;
            const apiBase = '@Html.Raw(ApiClient.BaseUrl)';
            let questions = [];
            try { questions = JSON.parse(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AssessmentJson))); }
            catch (e) { console.error('Assessment JSON parse error', e); }

            const questionList = document.getElementById('questionList');
            if (questionList && questions.length > 0) {
                questions.forEach(function (q, qi) {
                    const div = document.createElement('div');
                    div.className = 'mb-4';
                    let html = `<p class="fw-semibold mb-2">${qi + 1}. ${q.question}</p>`;
                    (q.options || []).forEach(function (opt, oi) {
                        const id = `q${qi}_o${oi}`;
                        html += `<div class="form-check">
                            <input class="form-check-input" type="radio" name="q${qi}" id="${id}" value="${oi}">
                            <label class="form-check-label" for="${id}">${opt}</label>
                        </div>`;
                    });
                    div.innerHTML = html;
                    questionList.appendChild(div);
                });
            } else if (questionList) {
                questionList.innerHTML = '<p class="text-muted">No questions available.</p>';
            }

            window.submitAssessment = async function () {
                const answers = [];
                let allAnswered = true;
                for (let i = 0; i < questions.length; i++) {
                    const sel = document.querySelector(`input[name="q${i}"]:checked`);
                    if (!sel) { allAnswered = false; break; }
                    answers.push(parseInt(sel.value));
                }
                if (!allAnswered) {
                    alert('Please answer all questions before submitting.');
                    return;
                }

                const btn = document.getElementById('submitAssessmentBtn');
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Submitting…';

                try {
                    const resp = await fetch(`${apiBase}/api/tni/${planId}/attempt`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ agentUsername: '@(Model.AgentUsername ?? "")', answers })
                    });
                    const text = await resp.text();
                    let data;
                    try { data = JSON.parse(text); } catch (_) { data = null; }
                    if (!resp.ok) { alert('Submission failed: ' + (data?.message ?? resp.statusText)); btn.disabled = false; btn.innerHTML = '<i class="bi bi-send me-1"></i>Submit Answers'; return; }
                    if (!data) { alert('Submission failed: server returned an unexpected response.'); btn.disabled = false; btn.innerHTML = '<i class="bi bi-send me-1"></i>Submit Answers'; return; }

                    // Render result
                    const passed = data.result === 'Pass';
                    let resultHtml = `
                        <div class="alert alert-${passed ? 'success' : 'warning'} mb-3">
                            <h5>${passed ? '🎉 Passed!' : '⚠️ Not Passed'}</h5>
                            <p class="mb-0">Score: <strong>${data.scorePercent}%</strong> (${data.correctAnswers} / ${data.totalQuestions} correct) — Pass mark: ${passMark}%</p>
                        </div>
                        <h6 class="fw-semibold mt-3 mb-2">Question Feedback</h6>`;
                    (data.feedback || []).forEach(function (fb, i) {
                        const q = questions[i] || {};
                        const opts = q.options || [];
                        resultHtml += `<div class="mb-3 p-3 rounded ${fb.isCorrect ? 'bg-success bg-opacity-10' : 'bg-warning bg-opacity-10'}">
                            <p class="fw-semibold mb-1">${i + 1}. ${fb.question}</p>
                            <p class="small mb-1">Your answer: <span class="${fb.isCorrect ? 'text-success' : 'text-danger'} fw-semibold">${opts[fb.agentAnswer] ?? fb.agentAnswer}</span>
                            ${!fb.isCorrect ? `— Correct: <span class="text-success fw-semibold">${opts[fb.correctAnswer] ?? fb.correctAnswer}</span>` : ''}</p>
                            <p class="small text-muted mb-0"><em>${fb.explanation}</em></p>
                        </div>`;
                    });

                    document.getElementById('assessmentForm').classList.add('d-none');
                    const resultDiv = document.getElementById('assessmentResult');
                    resultDiv.innerHTML = resultHtml;
                    resultDiv.classList.remove('d-none');
                } catch (ex) {
                    alert('Network error submitting assessment: ' + ex.message);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-send me-1"></i>Submit Answers';
                }
            };
        })();
    </script>
}
