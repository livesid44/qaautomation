@model List<ParameterClubViewModel>
@{
    ViewData["Title"] = "Parameter Clubs";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-collection me-2 text-success"></i>Parameter Clubs</h4>
        <p class="text-muted mb-0">Groups of parameters used to build evaluation form sections.</p>
    </div>
    <a href="/ParameterClubs/Designer" class="btn btn-success">
        <i class="bi bi-plus-lg me-1"></i>New Club
    </a>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-collection fs-1 d-block mb-2"></i>
                No parameter clubs yet. <a href="/ParameterClubs/Designer">Create the first one.</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Parameters</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@c.Name</td>
                                <td class="text-muted small">@(c.Description ?? "-")</td>
                                <td>
                                    <span class="badge bg-primary rounded-pill">@c.Items.Count</span>
                                    @if (c.Items.Any())
                                    {
                                        <span class="text-muted small ms-1">@string.Join(", ", c.Items.Take(3).Select(i => i.ParameterName))@(c.Items.Count > 3 ? "..." : "")</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @(c.IsActive ? "bg-success" : "bg-warning text-dark")">
                                        @(c.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a href="/ParameterClubs/Designer/@c.Id" class="btn btn-sm btn-outline-success me-1">
                                        <i class="bi bi-pencil-square me-1"></i>Designer
                                    </a>
                                    <form method="post" action="/ParameterClubs/Delete/@c.Id" class="d-inline"
                                          onsubmit="return confirm('Delete club @c.Name?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
