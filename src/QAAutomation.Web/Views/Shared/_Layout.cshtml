<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QA Automation</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/bootstrap-icons.min.css" />
    <style>
        body { background: #f0f2f5; }
        .sidebar {
            min-height: 100vh;
            background: #2c3e50;
            width: 250px;
            position: fixed;
            top: 0; left: 0;
            z-index: 100;
            padding-top: 0;
            overflow-y: auto;
        }
        .sidebar-brand {
            padding: 20px 16px;
            background: #1a252f;
            color: #fff;
            font-size: 1.1rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }
        .sidebar-brand:hover { color: #3498db; }
        .sidebar .nav-link {
            color: #bdc3c7;
            padding: 10px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-radius: 0;
            transition: all 0.2s;
            font-size: 0.92rem;
        }
        .sidebar .nav-link:hover, .sidebar .nav-link.active {
            color: #fff;
            background: #34495e;
        }
        .sidebar .nav-section {
            color: #7f8c8d;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 16px 20px 4px;
        }
        .main-content {
            margin-left: 250px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .topbar {
            background: #fff;
            border-bottom: 1px solid #e9ecef;
            padding: 10px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 99;
            box-shadow: 0 1px 3px rgba(0,0,0,.07);
        }
        .page-content { padding: 24px; flex: 1; }
        @@media (max-width: 768px) {
            .sidebar { width: 100%; min-height: auto; position: static; }
            .main-content { margin-left: 0; }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
    <div class="sidebar d-flex flex-column">
        <a class="sidebar-brand" href="/Dashboard">
            <i class="bi bi-shield-check fs-5"></i>
            QA Automation
        </a>
        <nav class="flex-column mt-2">
            <div class="nav-section">Main</div>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
               href="/Dashboard">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <div class="nav-section">Configuration</div>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Parameters" ? "active" : "")"
               href="/Parameters">
                <i class="bi bi-sliders"></i> Parameters
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ParameterClubs" ? "active" : "")"
               href="/ParameterClubs">
                <i class="bi bi-collection"></i> Parameter Clubs
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "RatingCriteria" ? "active" : "")"
               href="/RatingCriteria">
                <i class="bi bi-star-half"></i> Rating Criteria
            </a>

            <div class="nav-section">Forms</div>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "FormDesigner" ? "active" : "")"
               href="/FormDesigner">
                <i class="bi bi-layout-text-window"></i> Form Designer
            </a>

            <div class="nav-section">Audits</div>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Audit" ? "active" : "")"
               href="/Audit">
                <i class="bi bi-clipboard2-check"></i> Audit Records
            </a>

            @if (User.IsInRole("Admin"))
            {
                <div class="nav-section">Admin</div>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
                   href="/Users">
                    <i class="bi bi-people"></i> Users
                </a>
            }
        </nav>
    </div>
    <div class="main-content">
        <div class="topbar">
            <span class="fw-semibold text-secondary small">
                @ViewData["Title"]
            </span>
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted small">
                    <i class="bi bi-person-circle me-1"></i>@User.Identity?.Name
                    <span class="badge bg-secondary ms-1">@(User.IsInRole("Admin") ? "Admin" : "User")</span>
                </span>
                <form method="post" action="/Account/Logout" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </button>
                </form>
            </div>
        </div>
        <div class="page-content">
            @RenderBody()
        </div>
    </div>
}
else
{
    <div class="container-fluid">
        @RenderBody()
    </div>
}
<script src="/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
