<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AuraAI</title>
    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/bootstrap-icons.min.css" />
    <style>
        /* ── Brand Palette ─────────────────────────────────────────────────── */
        :root {
            --brand-red:    #CC1212;
            --brand-red-dk: #a30e0e;
            --brand-dark:   #1e2433;
            --brand-darker: #151920;
            --brand-amber:  #E87722;
            --brand-text:   #3d4354;
            --brand-muted:  #6c757d;
        }

        body { background: #f0f2f5; }

        /* ── Sidebar (offcanvas drawer) ───────────────────────────────────── */
        .sidebar {
            background: #ffffff;
            border-right: 1px solid #e5e7eb;
            width: 250px !important;
        }
        .sidebar .offcanvas-header {
            background: #f8f9fa;
            border-bottom: 2px solid var(--brand-red);
            padding: 0;
        }
        .sidebar .offcanvas-body {
            overflow-y: auto;
            overflow-x: hidden;
            scrollbar-width: thin;
            scrollbar-color: rgba(0,0,0,.12) transparent;
            padding: 0;
        }
        .sidebar .offcanvas-body::-webkit-scrollbar { width: 4px; }
        .sidebar .offcanvas-body::-webkit-scrollbar-track { background: transparent; }
        .sidebar .offcanvas-body::-webkit-scrollbar-thumb {
            background: rgba(0,0,0,.12);
            border-radius: 2px;
        }
        .sidebar .offcanvas-body::-webkit-scrollbar-thumb:hover { background: rgba(0,0,0,.25); }

        /* Brand / logo area */
        .sidebar-brand {
            padding: 14px 16px 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            flex-grow: 1;
        }
        .sidebar-brand img {
            height: 42px;
            width: auto;
            object-fit: contain;
        }
        .sidebar-brand:hover { opacity: .85; }

        /* LLM provider badge shown in the sidebar header */
        .llm-provider-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: .65rem;
            font-weight: 600;
            padding: 2px 7px;
            border-radius: 10px;
            white-space: nowrap;
            letter-spacing: .02em;
        }

        /* Nav links */
        .sidebar .nav-link {
            color: var(--brand-text);
            padding: 7px 16px 7px 22px;
            display: flex;
            align-items: center;
            gap: 8px;
            border-radius: 0;
            transition: all 0.18s;
            font-size: 0.85rem;
            border-left: 3px solid transparent;
        }
        .sidebar .nav-link:hover {
            color: var(--brand-red);
            background: rgba(204,18,18,.06);
            border-left-color: var(--brand-red);
        }
        .sidebar .nav-link.active {
            color: var(--brand-red);
            background: rgba(204,18,18,.1);
            border-left-color: var(--brand-red);
            font-weight: 600;
        }
        .sidebar .nav-link i { font-size: .95rem; flex-shrink: 0; }

        /* Collapsible group toggles */
        .nav-group-toggle {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            padding: 8px 16px;
            background: none;
            border: none;
            border-left: 3px solid transparent;
            color: #6b7280;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            cursor: pointer;
            transition: all 0.18s;
            text-align: left;
            margin-top: 6px;
        }
        .nav-group-toggle:hover {
            color: var(--brand-red);
            background: rgba(204,18,18,.04);
        }
        .nav-group-toggle.group-active {
            color: var(--brand-red);
        }
        .nav-group-toggle i.group-icon { font-size: .85rem; }
        .nav-group-toggle .toggle-chevron {
            margin-left: auto;
            font-size: .75rem;
            transition: transform 0.2s;
        }
        .nav-group-toggle[aria-expanded="false"] .toggle-chevron {
            transform: rotate(-90deg);
        }
        /* Indent child links slightly more */
        .nav-group-body .nav-link {
            padding-left: 36px;
        }
        /* Dashboard top-level link (no indent) */
        .nav-link-top {
            padding-left: 22px !important;
        }

        /* ── Main content ─────────────────────────────────────────────────── */
        .main-content {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Top bar */
        .topbar {
            background: #fff;
            border-bottom: 3px solid var(--brand-red);
            padding: 8px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 99;
            box-shadow: 0 2px 6px rgba(0,0,0,.08);
        }
        .topbar .page-title {
            font-weight: 600;
            color: var(--brand-dark);
            font-size: 0.9rem;
        }

        .page-content { padding: 24px; flex: 1; }

        /* ── Footer ───────────────────────────────────────────────────────── */
        .app-footer {
            background: #f8f9fa;
            color: var(--brand-muted);
            text-align: center;
            font-size: 0.75rem;
            padding: 10px 24px;
            border-top: 1px solid rgba(204,18,18,.2);
            letter-spacing: 0.02em;
            position: fixed;
            bottom: 0;
            right: 0;
            left: 0;
            z-index: 98;
        }
        .app-footer span { color: var(--brand-red); font-weight: 600; }

        /* extra bottom padding so page content isn't hidden behind fixed footer */
        .page-content { padding-bottom: 50px; }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
    <div class="offcanvas offcanvas-start sidebar" tabindex="-1" id="sidebarMenu" aria-labelledby="sidebarMenuLabel">
        <div class="offcanvas-header" style="flex-direction:column;align-items:stretch;padding-bottom:8px">
            <div class="d-flex align-items-center">
                <a class="sidebar-brand" href="@Url.Action("Index", "Analytics")" id="sidebarMenuLabel">
                    <img src="~/asset1.png" alt="AuraAI" />
                </a>
                <button type="button" class="btn-close me-1 ms-auto" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            @{
                var _llmProvider    = ViewData["LlmProvider"]    as string ?? "";
                var _llmDisplayName = ViewData["LlmDisplayName"] as string ?? "Simulated";
                var _llmIconClass   = ViewData["LlmIconClass"]   as string ?? "bi-gear";
                var _llmBadgeCss    = ViewData["LlmBadgeCss"]    as string ?? "background:#6c757d;color:#fff";
            }
            <div class="px-3 pb-1">
                <a href="@Url.Action("Index", "AiSettings")"
                   class="llm-provider-badge text-decoration-none"
                   style="@_llmBadgeCss"
                   title="LLM Provider: @_llmDisplayName — click to manage AI Settings">
                    <i class="bi @_llmIconClass"></i> @_llmDisplayName
                </a>
            </div>
        </div>
        <div class="offcanvas-body">
        <nav class="flex-column mt-1">
            @{
                var _ctrl   = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                var _action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

                bool _analyticsGroup = (_ctrl == "Analytics" && _action != "Index") || _ctrl == "InsightsChat";
                bool _setupGroup     = _ctrl is "Parameters" or "ParameterClubs" or "RatingCriteria" or "FormDesigner";
                bool _auditsGroup    = _ctrl is "Audit" or "AutoAudit" or "CallPipeline" or "HumanReview" or "Training";
                bool _adminGroup     = _ctrl is "AiSettings" or "AuditLog" or "Sampling" or "KnowledgeBase" or "Projects" or "Lobs" or "Users";
            }

            <!-- ── Dashboard (always visible) ────────────────────────────────── -->
            <a class="nav-link nav-link-top @(_ctrl is "Analytics" or "Dashboard" && _action == "Index" ? "active" : "")"
               href="@Url.Action("Index", "Analytics")">
                <i class="bi bi-speedometer2"></i> @L["NavDashboard"]
            </a>

            <!-- ── Analytics group ───────────────────────────────────────────── -->
            <button class="nav-group-toggle @(_analyticsGroup ? "group-active" : "")"
                    data-bs-toggle="collapse" data-bs-target="#grp-analytics"
                    aria-expanded="@(_analyticsGroup ? "true" : "false")" aria-controls="grp-analytics">
                <i class="bi bi-bar-chart-line group-icon"></i> @L["NavAnalytics"]
                <i class="bi bi-chevron-down toggle-chevron"></i>
            </button>
            <div class="collapse @(_analyticsGroup ? "show" : "")" id="grp-analytics">
                <div class="nav-group-body">
                    <a class="nav-link @(_ctrl == "Analytics" && _action == "Explainability" ? "active" : "")"
                       href="@Url.Action("Explainability", "Analytics")">
                        <i class="bi bi-shield-check"></i> @L["NavExplainability"]
                        <span class="badge ms-auto" style="font-size:.6rem;background:var(--brand-primary)">XAI</span>
                    </a>
                    <a class="nav-link @(_ctrl == "Analytics" && _action == "DecisionAssurance" ? "active" : "")"
                       href="@Url.Action("DecisionAssurance", "Analytics")">
                        <i class="bi bi-shield-exclamation"></i> @L["NavDecisionAssurance"]
                        <span class="badge ms-auto" style="font-size:.6rem;background:#5a2d82;color:#fff">ADV</span>
                    </a>
                    <a class="nav-link @(_ctrl == "InsightsChat" ? "active" : "")"
                       href="@Url.Action("Index", "InsightsChat")">
                        <i class="bi bi-chat-dots"></i> @L["NavInsightsChat"]
                    </a>
                </div>
            </div>

            <!-- ── QA Setup group (Configuration + Forms) ────────────────────── -->
            <button class="nav-group-toggle @(_setupGroup ? "group-active" : "")"
                    data-bs-toggle="collapse" data-bs-target="#grp-setup"
                    aria-expanded="@(_setupGroup ? "true" : "false")" aria-controls="grp-setup">
                <i class="bi bi-gear group-icon"></i> @L["NavQASetup"]
                <i class="bi bi-chevron-down toggle-chevron"></i>
            </button>
            <div class="collapse @(_setupGroup ? "show" : "")" id="grp-setup">
                <div class="nav-group-body">
                    <a class="nav-link @(_ctrl == "Parameters" ? "active" : "")"
                       href="@Url.Action("Index", "Parameters")">
                        <i class="bi bi-sliders"></i> @L["NavParameters"]
                    </a>
                    <a class="nav-link @(_ctrl == "ParameterClubs" ? "active" : "")"
                       href="@Url.Action("Index", "ParameterClubs")">
                        <i class="bi bi-collection"></i> @L["NavParameterClubs"]
                    </a>
                    <a class="nav-link @(_ctrl == "RatingCriteria" ? "active" : "")"
                       href="@Url.Action("Index", "RatingCriteria")">
                        <i class="bi bi-star-half"></i> @L["NavRatingCriteria"]
                    </a>
                    <a class="nav-link @(_ctrl == "FormDesigner" ? "active" : "")"
                       href="@Url.Action("Index", "FormDesigner")">
                        <i class="bi bi-layout-text-window"></i> @L["NavFormDesigner"]
                    </a>
                </div>
            </div>

            <!-- ── Audits group ───────────────────────────────────────────────── -->
            <button class="nav-group-toggle @(_auditsGroup ? "group-active" : "")"
                    data-bs-toggle="collapse" data-bs-target="#grp-audits"
                    aria-expanded="@(_auditsGroup ? "true" : "false")" aria-controls="grp-audits">
                <i class="bi bi-clipboard2-check group-icon"></i> @L["NavAudits"]
                <i class="bi bi-chevron-down toggle-chevron"></i>
            </button>
            <div class="collapse @(_auditsGroup ? "show" : "")" id="grp-audits">
                <div class="nav-group-body">
                    <a class="nav-link @(_ctrl == "Audit" ? "active" : "")"
                       href="@Url.Action("Index", "Audit")">
                        <i class="bi bi-clipboard2-check"></i> @L["NavAuditRecords"]
                    </a>
                    <a class="nav-link @(_ctrl == "AutoAudit" ? "active" : "")"
                       href="@Url.Action("Upload", "AutoAudit")">
                        <i class="bi bi-robot"></i> @L["NavAutoAudit"]
                        <span class="badge ms-auto" style="font-size:.6rem;background:var(--brand-red)">AI</span>
                    </a>
                    <a class="nav-link @(_ctrl == "CallPipeline" ? "active" : "")"
                       href="@Url.Action("Index", "CallPipeline")">
                        <i class="bi bi-diagram-3"></i> @L["NavCallPipeline"]
                        <span class="badge ms-auto bg-success" style="font-size:.6rem">Auto</span>
                    </a>
                    <a class="nav-link @(_ctrl == "HumanReview" && _action == "Index" ? "active" : "")"
                       href="@Url.Action("Index", "HumanReview")">
                        <i class="bi bi-person-check"></i> @L["NavHumanReview"]
                        <span class="badge ms-auto" style="font-size:.6rem;background:var(--brand-amber)">HITL</span>
                    </a>
                    <a class="nav-link @(_ctrl == "HumanReview" && _action == "Comparison" ? "active" : "")"
                       href="@Url.Action("Comparison", "HumanReview")">
                        <i class="bi bi-bar-chart-steps"></i> @L["NavAIvsHuman"]
                    </a>
                    <a class="nav-link @(_ctrl == "Training" ? "active" : "")"
                       href="@Url.Action("Index", "Training")">
                        <i class="bi bi-mortarboard"></i> @L["NavTrainingPlans"]
                        <span class="badge ms-auto" style="font-size:.6rem;background:var(--brand-amber)">TNI</span>
                    </a>
                </div>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <!-- ── Admin group ────────────────────────────────────────────── -->
                <button class="nav-group-toggle @(_adminGroup ? "group-active" : "")"
                        data-bs-toggle="collapse" data-bs-target="#grp-admin"
                        aria-expanded="@(_adminGroup ? "true" : "false")" aria-controls="grp-admin">
                    <i class="bi bi-shield-lock group-icon"></i> @L["NavAdmin"]
                    <i class="bi bi-chevron-down toggle-chevron"></i>
                </button>
                <div class="collapse @(_adminGroup ? "show" : "")" id="grp-admin">
                    <div class="nav-group-body">
                        <a class="nav-link @(_ctrl == "AiSettings" ? "active" : "")"
                           href="@Url.Action("Index", "AiSettings")">
                            <i class="bi bi-gear-wide-connected"></i> @L["NavAISettings"]
                            <span class="badge ms-auto bg-secondary" style="font-size:.6rem">RAG</span>
                        </a>
                        <a class="nav-link @(_ctrl == "AuditLog" ? "active" : "")"
                           href="@Url.Action("Index", "AuditLog")">
                            <i class="bi bi-journal-text"></i> @L["NavAuditLogs"]
                        </a>
                        <a class="nav-link @(_ctrl == "Sampling" ? "active" : "")"
                           href="@Url.Action("Index", "Sampling")">
                            <i class="bi bi-funnel"></i> @L["NavSamplingPolicies"]
                        </a>
                        <a class="nav-link @(_ctrl == "KnowledgeBase" ? "active" : "")"
                           href="@Url.Action("Index", "KnowledgeBase")">
                            <i class="bi bi-database"></i> @L["NavKnowledgeBase"]
                        </a>
                        <a class="nav-link @(_ctrl == "Projects" ? "active" : "")"
                           href="@Url.Action("Index", "Projects")">
                            <i class="bi bi-building"></i> @L["NavProjects"]
                        </a>
                        <a class="nav-link @(_ctrl == "Lobs" ? "active" : "")"
                           href="@Url.Action("Index", "Lobs")">
                            <i class="bi bi-layers"></i> @L["NavLinesOfBusiness"]
                        </a>
                        <a class="nav-link @(_ctrl == "Users" ? "active" : "")"
                           href="@Url.Action("Index", "Users")">
                            <i class="bi bi-people"></i> @L["NavUsers"]
                        </a>
                    </div>
                </div>
            }
        </nav>
        </div>
    </div>
    <div class="main-content">
        <div class="topbar">
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-sm btn-outline-secondary" type="button"
                        data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu"
                        aria-controls="sidebarMenu" title="Open menu">
                    <i class="bi bi-list fs-5"></i>
                </button>
                <span class="page-title">
                    @ViewData["Title"]
                </span>
            </div>
            <div class="d-flex align-items-center gap-3">
                @{
                    var projectId = int.TryParse(User.FindFirst("project_id")?.Value, out var pid) ? pid : 0;
                    var projectName = User.FindFirst("project_name")?.Value ?? "";
                    var projectCount = int.TryParse(User.FindFirst("project_count")?.Value, out var pc) ? pc : 1;
                }
                <!-- Language Switcher -->
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown"
                            title="@L["LangSwitcherLabel"]" aria-label="@L["LangSwitcherLabel"]">
                        <i class="bi bi-translate"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><h6 class="dropdown-header">@L["LangSwitcherLabel"]</h6></li>
                        @foreach (var lang in new (string code, string nameKey, string flag)[] {
                            ("en", "LangEnglish",  "🇬🇧"),
                            ("de", "LangGerman",   "🇩🇪"),
                            ("es", "LangSpanish",  "🇪🇸"),
                            ("fr", "LangFrench",   "🇫🇷"),
                            ("hi", "LangHindi",    "🇮🇳"),
                            ("ja", "LangJapanese", "🇯🇵")
                        })
                        {
                            var isCurrent = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == lang.code;
                            <li>
                                <form method="post" action="@Url.Action("SetLanguage", "Account")" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="culture" value="@lang.code" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    <button type="submit" class="dropdown-item @(isCurrent ? "active fw-semibold" : "")">
                                        @lang.flag @L[lang.nameKey]
                                    </button>
                                </form>
                            </li>
                        }
                    </ul>
                </div>
                @if (projectId > 0)
                {
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 py-2 px-3"
                          title="@L["NavCurrentProject"]">
                        <i class="bi bi-building me-1"></i>@projectName
                    </span>
                }
                <a href="@Url.Action("Index", "AiSettings")"
                   class="llm-provider-badge text-decoration-none d-none d-md-inline-flex"
                   style="@(ViewData["LlmBadgeCss"] as string ?? "background:#6c757d;color:#fff")"
                   title="LLM Provider: @(ViewData["LlmDisplayName"] as string ?? "Simulated") — click to manage AI Settings">
                    <i class="bi @(ViewData["LlmIconClass"] as string ?? "bi-gear")"></i>
                    @(ViewData["LlmDisplayName"] as string ?? "Simulated")
                </a>
                @if (projectCount > 1 || User.IsInRole("Admin"))
                {
                    var projectsJson = User.FindFirst("projects_list")?.Value ?? "[]";
                    List<(int Id, string Name)> allProjects = new();
                    try {
                        using var doc = System.Text.Json.JsonDocument.Parse(projectsJson);
                        foreach (var el in doc.RootElement.EnumerateArray())
                        {
                            // Support both camelCase ("id","name") and PascalCase ("Id","Name")
                            int pId = el.TryGetProperty("id", out var idProp) ? idProp.GetInt32()
                                    : el.TryGetProperty("Id", out var idPropPascal) ? idPropPascal.GetInt32() : 0;
                            string pName = el.TryGetProperty("name", out var nameProp) ? nameProp.GetString() ?? ""
                                         : el.TryGetProperty("Name", out var namePropPascal) ? namePropPascal.GetString() ?? "" : "";
                            if (pId > 0) allProjects.Add((pId, pName));
                        }
                    } catch (System.Text.Json.JsonException) {
                        // claims could not be parsed — switcher will show empty list
                        allProjects = new();
                    }
                    <!-- Project switcher dropdown -->
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown"
                                title="Switch project">
                            <i class="bi bi-arrow-left-right"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" style="min-width:220px">
                            <li><h6 class="dropdown-header">@L["NavSwitchProject"]</h6></li>
                            @if (!allProjects.Any())
                            {
                                <li><span class="dropdown-item-text text-muted small">@L["NavNoProjects"]</span></li>
                            }
                            @foreach (var (pId, pName) in allProjects)
                            {
                                <li>
                                    <form method="post" action="@Url.Action("SwitchProject", "Account")">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="projectId" value="@pId" />
                                        <input type="hidden" name="projectName" value="@pName" />
                                        <button type="submit"
                                                class="dropdown-item @(pId == projectId ? "active fw-semibold" : "")">
                                            <i class="bi bi-building me-2"></i>@pName
                                        </button>
                                    </form>
                                </li>
                            }
                        </ul>
                    </div>
                }
                <span class="text-muted small">
                    <i class="bi bi-person-circle me-1"></i>@User.Identity?.Name
                    <span class="badge bg-secondary ms-1">@(User.IsInRole("Admin") ? "Admin" : "User")</span>
                </span>
                <form method="post" action="@Url.Action("Logout", "Account")" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-box-arrow-right"></i> @L["NavLogout"]
                    </button>
                </form>
            </div>
        </div>
        <div class="page-content">
            @RenderBody()
        </div>
        <footer class="app-footer">
            &copy; @DateTime.UtcNow.Year <span>Tech Mahindra Ltd.</span> @L["FooterAllRightsReserved"]
            &nbsp;·&nbsp; AuraAI Intelligent Automation
        </footer>
    </div>
}
else
{
    <div class="container-fluid">
        @RenderBody()
    </div>
}
<script src="~/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
<script>
/* AuraAI — API connectivity diagnostics (visible in browser console & Network tab) */
(function () {
    var pingUrl = '@Url.Action("Ping", "Diagnostics")';
    console.groupCollapsed('%c[AuraAI] API connectivity check', 'color:#0d6efd;font-weight:bold');
    console.log('%cArchitecture note', 'font-weight:bold',
        '— The browser never calls the backend API directly.',
        'All API requests are proxied server-side:',
        'Browser → Web Server → Backend API');
    console.log('Calling diagnostics endpoint:', pingUrl);
    fetch(pingUrl, { credentials: 'same-origin', cache: 'no-store' })
        .then(function (r) { return r.json(); })
        .then(function (d) {
            console.log('%cCall flow:', 'font-weight:bold', d.callFlow);
            if (d.ok) {
                console.log('%c✔ API reachable', 'color:green;font-weight:bold',
                    '| URL:', d.apiUrl,
                    '| HTTP', d.statusCode,
                    '| latency:', d.latencyMs + ' ms');
            } else {
                console.error('%c✘ API returned error', 'color:red;font-weight:bold',
                    '| URL:', d.apiUrl,
                    '| HTTP', d.statusCode,
                    '| latency:', d.latencyMs + ' ms',
                    d.error ? '| Error: ' + d.error : '');
            }
            console.log('Full ping result:', d);
        })
        .catch(function (err) {
            console.error('%c✘ API ping request failed', 'color:red;font-weight:bold',
                '— could not reach the diagnostics endpoint.', err);
            console.log('Hint: ensure the web server is running and you are logged in.');
            console.log('Remember: the browser calls /diagnostics/ping on the Web Server,',
                'which then forwards the check to the Backend API. Neither hop is direct from the browser.');
        });
    console.groupEnd();
}());
</script>
</body>
</html>
