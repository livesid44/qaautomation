@model SelectProjectViewModel
@{
    Layout = null; // standalone page like Login
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Select Project - QA Automation</title>
    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/bootstrap-icons.min.css" />
    <style>
        body { background: #f0f2f5; }
        .card { max-width: 600px; }
    </style>
</head>
<body class="d-flex justify-content-center align-items-center min-vh-100">
<div class="card border-0 shadow-sm w-100">
    <div class="card-header bg-white border-0 pt-4 text-center">
        <i class="bi bi-building fs-2 text-primary"></i>
        <h5 class="fw-bold mt-2 mb-0">@L["SelectProjectTitle"]</h5>
        <p class="text-muted small mt-1">Welcome back, <strong>@Model.Username</strong>. Choose which project to work on.</p>
    </div>
    <div class="card-body pb-4">
        <div class="row g-3">
            @foreach (var project in Model.Projects)
            {
                <div class="col-12">
                    <form method="post" action="@Url.Action("SelectProject", "Account")">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="projectId" value="@project.Id" />
                        <input type="hidden" name="projectName" value="@project.Name" />
                        <button type="submit"
                                class="btn btn-outline-primary w-100 text-start d-flex align-items-center gap-3 py-3 px-4">
                            <div class="rounded-circle bg-primary bg-opacity-10 p-2 flex-shrink-0">
                                <i class="bi bi-building text-primary"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">@project.Name</div>
                                @if (!string.IsNullOrEmpty(project.Description))
                                {
                                    <div class="text-muted small">@project.Description</div>
                                }
                                <div class="text-muted small">@project.LobCount LOB@(project.LobCount != 1 ? "s" : "")</div>
                            </div>
                            <i class="bi bi-chevron-right ms-auto text-muted"></i>
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
    <div class="card-footer bg-white border-0 text-center pb-4">
        <form method="post" action="@Url.Action("Logout", "Account")">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-link text-muted small">Sign out</button>
        </form>
    </div>
</div>
<script src="~/js/bootstrap.bundle.min.js"></script>
</body>
</html>
