@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — AuraAI</title>
    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/bootstrap-icons.min.css" />
    <style>
        :root {
            --brand-red:    #CC1212;
            --brand-red-dk: #a30e0e;
            --brand-dark:   #1e2433;
            --brand-amber:  #E87722;
        }

        *, *::before, *::after { box-sizing: border-box; }

        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            background: linear-gradient(145deg, #f0f2f5 0%, #e8ecf0 55%, #f5efef 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-family: system-ui, -apple-system, sans-serif;
        }

        /* subtle dot grid */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: radial-gradient(circle, rgba(204,18,18,.08) 1px, transparent 1px);
            background-size: 30px 30px;
            pointer-events: none;
            z-index: 0;
        }

        .login-wrap {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 420px;
            padding: 16px;
        }

        .login-card {
            border-radius: 16px;
            box-shadow: 0 24px 64px rgba(0,0,0,.12);
            border: 1px solid #e5e7eb;
            overflow: hidden;
            background: #fff;
        }

        /* Card header — light strip with red bottom border */
        .login-header {
            background: #ffffff;
            border-bottom: 3px solid var(--brand-red);
            padding: 28px 32px 24px;
            text-align: center;
            position: relative;
        }
        .login-header::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 3px;
            background: var(--brand-amber);
        }

        .login-header img {
            height: 64px;
            width: auto;
            object-fit: contain;
        }

        .login-header .tagline {
            color: var(--brand-dark);
            font-size: .82rem;
            letter-spacing: .06em;
            text-transform: uppercase;
            margin-top: 6px;
            font-weight: 500;
        }

        .login-body { padding: 32px; }

        .form-control:focus {
            border-color: var(--brand-red);
            box-shadow: 0 0 0 .2rem rgba(204,18,18,.18);
        }

        .input-group-text {
            background: #f8f9fa;
            border-right: none;
            color: var(--brand-dark);
        }
        .input-group .form-control { border-left: none; }

        .btn-brand {
            background: var(--brand-red);
            border-color: var(--brand-red);
            color: #fff;
            font-weight: 600;
            letter-spacing: .02em;
            transition: background .18s, border-color .18s;
        }
        .btn-brand:hover, .btn-brand:focus {
            background: var(--brand-red-dk);
            border-color: var(--brand-red-dk);
            color: #fff;
        }

        /* Footer */
        .login-footer {
            text-align: center;
            color: rgba(0,0,0,.45);
            font-size: .72rem;
            margin-top: 20px;
            letter-spacing: .03em;
        }
        .login-footer span { color: var(--brand-red); font-weight: 600; }
    </style>
</head>
<body>
<div class="login-wrap">
    <div class="login-card">
        <div class="login-header">
            <img src="~/asset1.png" alt="AuraAI Intelligent Automation" />
            <p class="tagline mb-0">Intelligent Automation Platform</p>
        </div>
        <div class="login-body">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger alert-dismissible fade show py-2" role="alert">
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div><i class="bi bi-exclamation-circle me-1"></i>@err.ErrorMessage</div>
                    }
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
                </div>
            }
            <form asp-action="Login" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                <div class="mb-3">
                    <label asp-for="Username" class="form-label fw-semibold">Username</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input asp-for="Username" class="form-control" placeholder="Enter username" autocomplete="username" />
                    </div>
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-semibold">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn btn-brand w-100 py-2">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
                </button>
            </form>
        </div>
    </div>

    <div class="login-footer">
        &copy; @DateTime.UtcNow.Year <span>Tech Mahindra Ltd.</span> All rights reserved.
    </div>
</div>
<script src="~/js/bootstrap.bundle.min.js"></script>
</body>
</html>
