@model DashboardViewModel
@{
    ViewData["Title"] = L["PageTitleDashboard"].Value;
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">@L["DashWelcomeBack"] @Model.Username!</h4>
        @if (!string.IsNullOrEmpty(Model.CurrentProjectName))
        {
            <p class="text-muted mb-0">
                <i class="bi bi-building me-1 text-primary"></i>
                <strong class="text-primary">@Model.CurrentProjectName</strong>
                — @L["DashOverview"]
            </p>
        }
        else
        {
            <p class="text-muted mb-0">@L["DashOverview"]</p>
        }
    </div>
    <span class="badge bg-primary py-2 px-3 fs-6">@Model.Role</span>
</div>

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-sliders fs-4 text-primary"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.ParameterCount</div>
                    <div class="text-muted small">@L["DashParameterCount"]</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="bi bi-collection fs-4 text-success"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.ParameterClubCount</div>
                    <div class="text-muted small">@L["DashParameterClubs"]</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="bi bi-star-half fs-4 text-warning"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.RatingCriteriaCount</div>
                    <div class="text-muted small">@L["DashRatingCriteria"]</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-info bg-opacity-10 p-3">
                    <i class="bi bi-layout-text-window fs-4 text-info"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.EvaluationFormCount</div>
                    <div class="text-muted small">@L["DashEvaluationForms"]</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="bi bi-clipboard2-check fs-4 text-warning"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.AuditCount</div>
                    <div class="text-muted small">@L["DashAuditRecords"]</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-4 pb-0">
        <h6 class="fw-bold mb-0">@L["DashQuickNavigation"]</h6>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <a href="@Url.Action("Index", "Parameters")" class="btn btn-outline-primary w-100 py-3">
                    <i class="bi bi-sliders d-block fs-4 mb-1"></i>
                    @L["DashManageParameters"]
                </a>
            </div>
            <div class="col-md-3">
                <a href="@Url.Action("Index", "ParameterClubs")" class="btn btn-outline-success w-100 py-3">
                    <i class="bi bi-collection d-block fs-4 mb-1"></i>
                    @L["DashParameterClubs"]
                </a>
            </div>
            <div class="col-md-3">
                <a href="@Url.Action("Index", "RatingCriteria")" class="btn btn-outline-warning w-100 py-3">
                    <i class="bi bi-star-half d-block fs-4 mb-1"></i>
                    @L["DashRatingCriteria"]
                </a>
            </div>
            <div class="col-md-3">
                <a href="@Url.Action("Index", "FormDesigner")" class="btn btn-outline-info w-100 py-3">
                    <i class="bi bi-layout-text-window d-block fs-4 mb-1"></i>
                    @L["NavFormDesigner"]
                </a>
            </div>
            <div class="col-md-3">
                <a href="@Url.Action("Index", "Audit")" class="btn btn-outline-warning w-100 py-3">
                    <i class="bi bi-clipboard2-check d-block fs-4 mb-1"></i>
                    @L["DashAuditRecords"]
                </a>
            </div>
        </div>
    </div>
</div>
