@model LobViewModel
@{
    ViewData["Title"] = L["BtnEdit"].Value + " — " + Model.Name;
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-0"><i class="bi bi-layers me-2 text-primary"></i>@Model.Name</h5>
        <small class="text-muted">Project: <strong>@Model.ProjectName</strong></small>
    </div>
    <a href="@Url.Action("Index", "Lobs", new { projectId = Model.ProjectId })" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>@L["BtnBack"]
    </a>
</div>
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible py-2"><button type="button" class="btn-close" data-bs-dismiss="alert"></button>@TempData["Success"]</div>
}
<div class="card border-0 shadow-sm" style="max-width:520px">
    <div class="card-body">
        <form method="post" action="@Url.Action("Edit", "Lobs", new { id = Model.Id })">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label fw-semibold small">@L["LblName"] *</label>
                <input name="name" class="form-control" value="@Model.Name" required maxlength="200" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold small">@L["LblDescription"]</label>
                <textarea name="description" class="form-control" rows="2">@Model.Description</textarea>
            </div>
            <div class="mb-3 form-check">
                <input type="checkbox" name="isActive" value="true" class="form-check-input" id="isActive"
                       @(Model.IsActive ? "checked" : "") />
                <input type="hidden" name="isActive" value="false" />
                <label for="isActive" class="form-check-label small">@L["LblActive"]</label>
            </div>
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-check2 me-1"></i>@L["BtnSave"]</button>
        </form>
    </div>
</div>
