@model List<LobViewModel>
@{
    ViewData["Title"] = "Lines of Business";
    var projects = ViewData["Projects"] as List<ProjectViewModel> ?? new();
    var filterProjectId = ViewData["FilterProjectId"] as int?;
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-layers me-2 text-primary"></i>Lines of Business</h4>
        <p class="text-muted mb-0">Each LOB belongs to a Project and groups related Evaluation Forms.</p>
    </div>
    <a href="/Lobs/Create@(filterProjectId.HasValue ? $"?projectId={filterProjectId}" : "")" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>New LOB
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible py-2"><button type="button" class="btn-close" data-bs-dismiss="alert"></button>@TempData["Success"]</div>
}

<!-- Filter by project -->
<div class="mb-3 d-flex gap-2 align-items-center flex-wrap">
    <span class="text-muted small fw-semibold">Filter:</span>
    <a href="/Lobs" class="btn btn-sm @(filterProjectId == null ? "btn-primary" : "btn-outline-secondary")">All Projects</a>
    @foreach (var p in projects)
    {
        <a href="/Lobs?projectId=@p.Id"
           class="btn btn-sm @(filterProjectId == p.Id ? "btn-primary" : "btn-outline-secondary")">
            @p.Name
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-layers fs-1 d-block mb-2"></i>
            No LOBs found. <a href="/Lobs/Create@(filterProjectId.HasValue ? $"?projectId={filterProjectId}" : "")">Create one</a>.
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Project</th>
                    <th>Forms</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var lob in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@lob.Name</div>
                            @if (!string.IsNullOrEmpty(lob.Description))
                            {
                                <div class="text-muted small">@lob.Description</div>
                            }
                        </td>
                        <td><span class="badge bg-primary bg-opacity-10 text-primary">@lob.ProjectName</span></td>
                        <td><span class="text-muted">@lob.FormCount</span></td>
                        <td>
                            @if (lob.IsActive) { <span class="badge bg-success">Active</span> }
                            else { <span class="badge bg-secondary">Inactive</span> }
                        </td>
                        <td class="text-muted small">@lob.CreatedAt.ToString("MMM d, yyyy")</td>
                        <td>
                            <a href="/Lobs/Edit/@lob.Id" class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="/Lobs/Delete" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@lob.Id" />
                                <input type="hidden" name="projectId" value="@lob.ProjectId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Delete this LOB?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
