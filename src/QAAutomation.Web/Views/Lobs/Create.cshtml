@model LobViewModel
@{
    ViewData["Title"] = L["LobsCreate"].Value;
    var projects = ViewData["Projects"] as List<ProjectViewModel> ?? new();
    var defaultProjectId = ViewData["DefaultProjectId"] as int? ?? 0;
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold"><i class="bi bi-plus-circle me-2 text-primary"></i>New Line of Business</h5>
    <a href="@Url.Action("Index", "Lobs")" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>
<div class="card border-0 shadow-sm" style="max-width:520px">
    <div class="card-body">
        <form method="post" action="@Url.Action("Create", "Lobs")">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label fw-semibold small">Project *</label>
                <select name="projectId" class="form-select" required>
                    <option value="">— Select Project —</option>
                    @foreach (var p in projects.Where(x => x.IsActive))
                    {
                        if (p.Id == defaultProjectId) {
                            <option value="@p.Id" selected>@p.Name</option>
                        } else {
                            <option value="@p.Id">@p.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold small">LOB Name *</label>
                <input name="name" class="form-control" required maxlength="200" placeholder="e.g. Customer Support Call" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold small">Description</label>
                <textarea name="description" class="form-control" rows="2" placeholder="Optional description"></textarea>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check2 me-1"></i>Create LOB</button>
            <a href="@Url.Action("Index", "Lobs")" class="btn btn-link text-muted ms-2">Cancel</a>
        </form>
    </div>
</div>
