@model AiSettingsViewModel
@{
    ViewData["Title"] = "AI Settings";
}
@section Styles {
<style>
    .settings-section { border-left:4px solid #0d6efd; }
    .provider-badge { font-size:.7rem; padding:2px 8px; border-radius:12px; }
    .status-dot { width:10px; height:10px; border-radius:50%; display:inline-block; }
</style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-gear-wide-connected me-2 text-primary"></i>AI Settings</h4>
        <p class="text-muted mb-0">Configure LLM, sentiment provider, and RAG settings. Values are stored in the database.</p>
    </div>
    <div>
        @if (Model.IsConfigured)
        {
            <span class="badge bg-success"><span class="status-dot bg-white me-1"></span>LLM Connected</span>
        }
        else
        {
            <span class="badge bg-warning text-dark"><span class="status-dot bg-dark me-1" style="opacity:.5"></span>Using Mock / Simulated</span>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="post">
    @Html.AntiForgeryToken()

    <div class="row g-4">
        <div class="col-lg-8">

            <!-- LLM Configuration -->
            <div class="card border-0 shadow-sm mb-4 settings-section">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-cpu me-2 text-primary"></i>Quality Scoring LLM</h6>
                    <div class="text-muted small">Used for auto-auditing QA parameters. LLM-type parameters are scored directly; KnowledgeBased parameters use RAG context.</div>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small">Provider</label>
                            <select name="LlmProvider" class="form-select" id="llmProvider" onchange="toggleLlmFields()">
                                @if (Model.LlmProvider == "OpenAI") {
                                    <option value="AzureOpenAI">Azure OpenAI</option>
                                    <option value="OpenAI" selected>OpenAI (Direct)</option>
                                    <option value="Google">Google Gemini</option>
                                } else if (Model.LlmProvider == "Google") {
                                    <option value="AzureOpenAI">Azure OpenAI</option>
                                    <option value="OpenAI">OpenAI (Direct)</option>
                                    <option value="Google" selected>Google Gemini</option>
                                } else {
                                    <option value="AzureOpenAI" selected>Azure OpenAI</option>
                                    <option value="OpenAI">OpenAI (Direct)</option>
                                    <option value="Google">Google Gemini</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-8" id="llmEndpointField" style="@(Model.LlmProvider == "Google" ? "display:none" : "")">
                            <label class="form-label fw-semibold small">Endpoint URL</label>
                            <input type="text" name="LlmEndpoint" class="form-control" value="@Model.LlmEndpoint"
                                   placeholder="https://your-resource.cognitiveservices.azure.com/openai/v1/" />
                            <div class="form-text">Azure AI Foundry endpoint, base resource URL, or full deployment URL — all are accepted. Leave blank to use simulated mock responses.</div>
                        </div>
                        <div class="col-md-6" id="llmApiKeyField" style="@(Model.LlmProvider == "Google" ? "display:none" : "")">
                            <label class="form-label fw-semibold small">API Key or Bearer Token</label>
                            <input type="password" name="LlmApiKey" class="form-control" value="@Model.LlmApiKey"
                                   placeholder="@(ViewData["LlmKeyIsSet"] as bool? == true ? "Key is saved — enter a new value to replace it" : "Enter API key or Bearer token")"
                                   autocomplete="new-password" />
                            @if (ViewData["LlmKeyIsSet"] as bool? == true)
                            {
                                <div class="form-text text-success"><i class="bi bi-check-circle-fill me-1"></i>API key is saved. Leave blank to keep the existing key.</div>
                            }
                            else
                            {
                                <div class="form-text text-muted">Paste your Azure OpenAI API key, or an Entra ID bearer token obtained via <code>az account get-access-token --resource https://cognitiveservices.azure.com --query accessToken -o tsv</code>.</div>
                            }
                        </div>
                        <div class="col-md-4" id="llmDeploymentField" style="@(Model.LlmProvider == "Google" ? "display:none" : "")">
                            <label class="form-label fw-semibold small">Deployment / Model</label>
                            <input type="text" name="LlmDeployment" class="form-control" value="@Model.LlmDeployment"
                                   placeholder="gpt-4o" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-semibold small">Temperature</label>
                            <input type="number" name="LlmTemperature" class="form-control" value="@Model.LlmTemperature.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                   min="0" max="2" step="0.1" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sentiment Provider -->
            <div class="card border-0 shadow-sm mb-4" style="border-left:4px solid #fd7e14 !important; border-left-style:solid !important;">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-emoji-smile me-2 text-warning"></i>Sentiment &amp; Emotion Analysis</h6>
                    <div class="text-muted small">Provider for sentiment scoring, emotion detection, and coaching recommendations.</div>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small">Sentiment Provider</label>
                            <select name="SentimentProvider" class="form-select" id="sentimentProvider" onchange="toggleLangFields()">
                                @if (Model.SentimentProvider == "OpenAI") {
                                    <option value="AzureOpenAI">Azure OpenAI (same as LLM)</option>
                                    <option value="OpenAI" selected>OpenAI (Direct)</option>
                                    <option value="AzureLanguage">Azure Language Service</option>
                                    <option value="Google">Google Gemini</option>
                                } else if (Model.SentimentProvider == "AzureLanguage") {
                                    <option value="AzureOpenAI">Azure OpenAI (same as LLM)</option>
                                    <option value="OpenAI">OpenAI (Direct)</option>
                                    <option value="AzureLanguage" selected>Azure Language Service</option>
                                    <option value="Google">Google Gemini</option>
                                } else if (Model.SentimentProvider == "Google") {
                                    <option value="AzureOpenAI">Azure OpenAI (same as LLM)</option>
                                    <option value="OpenAI">OpenAI (Direct)</option>
                                    <option value="AzureLanguage">Azure Language Service</option>
                                    <option value="Google" selected>Google Gemini</option>
                                } else {
                                    <option value="AzureOpenAI" selected>Azure OpenAI (same as LLM)</option>
                                    <option value="OpenAI">OpenAI (Direct)</option>
                                    <option value="AzureLanguage">Azure Language Service</option>
                                    <option value="Google">Google Gemini</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-8 lang-fields" id="langFields" style="@(Model.SentimentProvider == "AzureLanguage" ? "" : "display:none")">
                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="form-label fw-semibold small">Language Endpoint</label>
                                    <input type="text" name="LanguageEndpoint" class="form-control" value="@Model.LanguageEndpoint"
                                           placeholder="https://your-lang.cognitiveservices.azure.com/" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-semibold small">Language API Key</label>
                                    <input type="password" name="LanguageApiKey" class="form-control" value="@Model.LanguageApiKey"
                                           placeholder="@(ViewData["LangKeyIsSet"] as bool? == true ? "Key is saved — enter a new value to replace it" : "Enter API key")"
                                           autocomplete="new-password" />
                                    @if (ViewData["LangKeyIsSet"] as bool? == true)
                                    {
                                        <div class="form-text text-success"><i class="bi bi-check-circle-fill me-1"></i>Language key is saved.</div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RAG Configuration -->
            <div class="card border-0 shadow-sm mb-4" style="border-left:4px solid #198754 !important; border-left-style:solid !important;">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-database me-2 text-success"></i>RAG (Knowledge-Based Evaluation)</h6>
                    <div class="text-muted small">Controls how many knowledge base chunks are injected per KnowledgeBased-type parameter when scoring.</div>
                </div>
                <div class="card-body">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold small">Top-K Chunks</label>
                            <input type="number" name="RagTopK" class="form-control" value="@Model.RagTopK" min="1" max="10" />
                            <div class="form-text">How many KB excerpts to include in the LLM prompt per KnowledgeBased field.</div>
                        </div>
                        <div class="col-md-9 d-flex align-items-start gap-3 pt-3">
                            <div class="alert alert-success mb-0 py-2 px-3 small flex-fill">
                                <i class="bi bi-lightbulb me-1"></i>
                                <strong>How RAG works:</strong> When scoring a parameter marked as <em>KnowledgeBased</em>,
                                the system retrieves the most relevant documents from your Knowledge Base and includes them as
                                context in the LLM prompt. This grounds the evaluation in your actual process documentation.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Speech-to-Text Configuration -->
            <div class="card border-0 shadow-sm mb-4" style="border-left:4px solid #6f42c1 !important; border-left-style:solid !important;">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="fw-bold mb-0">
                        <i class="bi bi-mic me-2 text-purple" style="color:#6f42c1"></i>Speech-to-Text
                        @if (Model.IsSpeechConfigured)
                        {
                            <span class="badge bg-success ms-2" style="font-size:.65rem">Configured</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary ms-2" style="font-size:.65rem">Not configured</span>
                        }
                    </h6>
                    <div class="text-muted small">
                        Used by the Call Pipeline to automatically transcribe audio recordings (.mp3, .wav, .ogg, .flac, .m4a, etc.)
                        before QA scoring. Text transcripts bypass this step entirely.
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label fw-semibold small">STT Provider</label>
                            <select name="SpeechProvider" class="form-select" id="speechProvider" onchange="toggleSpeechFields()">
                                @if (Model.SpeechProvider == "Google") {
                                    <option value="Azure">Azure Cognitive Services</option>
                                    <option value="Google" selected>Google Cloud STT</option>
                                } else {
                                    <option value="Azure" selected>Azure Cognitive Services</option>
                                    <option value="Google">Google Cloud STT</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4" id="speechEndpointField" style="@(Model.SpeechProvider == "Google" ? "display:none" : "")">
                            <label class="form-label fw-semibold small">Azure Region or Endpoint</label>
                            <input type="text" name="SpeechEndpoint" class="form-control" value="@Model.SpeechEndpoint"
                                   placeholder="e.g. eastus  or  https://eastus.api.cognitive.microsoft.com" />
                            <div class="form-text">
                                Azure Speech Service region code (e.g. <code>eastus</code>) or a full custom endpoint URL.
                            </div>
                        </div>
                        <div class="col-md-5" id="speechApiKeyField" style="@(Model.SpeechProvider == "Google" ? "display:none" : "")">
                            <label class="form-label fw-semibold small">Azure Speech API Key</label>
                            <input type="password" name="SpeechApiKey" class="form-control" value="@Model.SpeechApiKey"
                                   placeholder="@(ViewData["SpeechKeyIsSet"] as bool? == true ? "Key is saved — enter a new value to replace it" : "Enter Azure Speech subscription key")"
                                   autocomplete="new-password" />
                            @if (ViewData["SpeechKeyIsSet"] as bool? == true)
                            {
                                <div class="form-text text-success"><i class="bi bi-check-circle-fill me-1"></i>Azure Speech key is saved.</div>
                            }
                        </div>
                        <div class="col-12" id="googleSttNote" style="@(Model.SpeechProvider == "Google" ? "" : "display:none")">
                            <div class="alert alert-info mb-0 py-2 px-3 small">
                                <i class="bi bi-google me-1"></i>
                                <strong>Google Cloud STT</strong> uses your <strong>Google API Key</strong> (configured below).
                                Audio files up to 10 MB are transcribed inline. Files hosted in Google Cloud Storage are also supported.
                                Requires the <em>Cloud Speech-to-Text API</em> enabled in your Google Cloud project.
                            </div>
                        </div>
                    </div>
                    <div class="alert alert-light border mt-3 mb-0 py-2 px-3 small">
                        <i class="bi bi-info-circle me-1"></i>
                        <strong>How it works:</strong> When the Call Pipeline encounters an audio URL (.mp3, .wav, .ogg, .flac, .m4a, .aac, .opus),
                        it submits a transcription job to the configured provider, polls until the transcript is ready,
                        then feeds the text transcript to the LLM for QA scoring — fully automated, no human in the loop.
                    </div>
                </div>
            </div>

            <!-- Google Configuration -->
            <div class="card border-0 shadow-sm mb-4" style="border-left:4px solid #ea4335 !important; border-left-style:solid !important;">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="fw-bold mb-0">
                        <i class="bi bi-stars me-2" style="color:#ea4335"></i>Google AI Configuration
                        @if (!string.IsNullOrWhiteSpace(Model.GoogleApiKey) || ViewData["GoogleKeyIsSet"] as bool? == true)
                        {
                            <span class="badge bg-success ms-2" style="font-size:.65rem">Key configured</span>
                        }
                    </h6>
                    <div class="text-muted small">
                        Required when LLM Provider, Sentiment Provider, or STT Provider is set to <strong>Google</strong>.
                        Uses the Google AI Studio API key — no Google Cloud project required for Gemini.
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Google API Key</label>
                            <input type="password" name="GoogleApiKey" class="form-control" value="@Model.GoogleApiKey"
                                   placeholder="@(ViewData["GoogleKeyIsSet"] as bool? == true ? "Key is saved — enter a new value to replace it" : "Enter Google AI Studio API key")"
                                   autocomplete="new-password" />
                            @if (ViewData["GoogleKeyIsSet"] as bool? == true)
                            {
                                <div class="form-text text-success"><i class="bi bi-check-circle-fill me-1"></i>Google API key is saved. Leave blank to keep the existing key.</div>
                            }
                            else
                            {
                                <div class="form-text text-muted">
                                    Get a free key at <a href="https://aistudio.google.com/app/apikey" target="_blank" rel="noopener">Google AI Studio</a>.
                                    The same key is used for Gemini LLM, sentiment analysis, and Google Cloud STT.
                                </div>
                            }
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small">Gemini Model</label>
                            <input type="text" name="GoogleGeminiModel" class="form-control" value="@Model.GoogleGeminiModel"
                                   placeholder="gemini-1.5-pro" />
                            <div class="form-text">Model used for LLM and sentiment analysis. Examples: <code>gemini-1.5-pro</code>, <code>gemini-2.0-flash</code>.</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Backend API Connection -->
            <div class="card border-0 shadow-sm mb-4" style="border-left:4px solid #20c997 !important; border-left-style:solid !important;">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-plug me-2" style="color:#20c997"></i>Backend API Connection</h6>
                    <div class="text-muted small">The URL of the QAAutomation REST API this web application communicates with.</div>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Current API Base URL</label>
                        <div class="input-group">
                            <input type="text" class="form-control" value="@(ViewData["ApiBaseUrl"])" readonly />
                            <span class="input-group-text"><i class="bi bi-lock text-muted"></i></span>
                        </div>
                        <div class="form-text">
                            To change this URL, update the <code>ApiBaseUrl</code> key in
                            <code>appsettings.json</code> (or set the environment variable
                            <code>ApiBaseUrl</code>) and restart the web application.
                        </div>
                    </div>

                    <!-- Architecture call-flow diagram -->
                    <div class="alert alert-light border mt-2 mb-0 py-2 px-3 small">
                        <div class="fw-semibold mb-1"><i class="bi bi-diagram-3 me-1"></i>How API calls work</div>
                        <div class="d-flex align-items-center gap-1 flex-wrap">
                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-2 py-1">
                                <i class="bi bi-browser-chrome me-1"></i>Browser
                            </span>
                            <i class="bi bi-arrow-right text-muted"></i>
                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1">
                                <i class="bi bi-hdd-rack me-1"></i>Web Server <span class="text-muted fw-normal">(this app)</span>
                            </span>
                            <i class="bi bi-arrow-right text-muted"></i>
                            <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-2 py-1">
                                <i class="bi bi-server me-1"></i>Backend API
                            </span>
                        </div>
                        <div class="text-muted mt-1">
                            The browser <strong>never calls the API directly</strong>. Every API request originates from the Web Server (server-side
                            <code>HttpClient</code> in <code>ApiClient</code>), so no backend calls appear in the browser's Network tab.
                            Use <strong>AI Settings → Live Connectivity Test</strong> below or open the browser Console to see the
                            server-side ping result.
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Right panel -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-info-circle me-2 text-info"></i>Configuration Status</h6>
                    <dl class="row small mb-0">
                        <dt class="col-5 text-muted">LLM</dt>
                        <dd class="col-7">
                            @if (Model.IsConfigured)
                            {
                                <span class="badge bg-success">Connected</span>
                                <div class="text-muted" style="font-size:.75rem">
                                    @if (Model.LlmProvider == "Google") {
                                        @($"Google · {Model.GoogleGeminiModel}")
                                    } else {
                                        @($"{Model.LlmProvider} · {Model.LlmDeployment}")
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Mock / Simulated</span>
                            }
                        </dd>
                        <dt class="col-5 text-muted">Sentiment</dt>
                        <dd class="col-7"><span class="text-muted small">@Model.SentimentProvider</span></dd>
                        <dt class="col-5 text-muted">RAG Top-K</dt>
                        <dd class="col-7"><span class="text-muted small">@Model.RagTopK chunks</span></dd>
                        <dt class="col-5 text-muted">Speech STT</dt>
                        <dd class="col-7">
                            @if (Model.IsSpeechConfigured)
                            {
                                <span class="badge bg-success">Configured</span>
                                <div class="text-muted" style="font-size:.75rem">@Model.SpeechProvider</div>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Not configured</span>
                            }
                        </dd>
                        @if (ViewData["GoogleKeyIsSet"] as bool? == true)
                        {
                            <dt class="col-5 text-muted">Google Key</dt>
                            <dd class="col-7"><span class="badge bg-success" style="font-size:.65rem">Saved</span></dd>
                        }
                        <dt class="col-5 text-muted">Last Updated</dt>
                        <dd class="col-7 small text-muted">@(Model.UpdatedAt == default ? "Never" : Model.UpdatedAt.ToString("MMM d, yyyy HH:mm"))</dd>
                    </dl>
                </div>
            </div>
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-2"><i class="bi bi-database me-2 text-success"></i>Knowledge Base</h6>
                    <p class="text-muted small mb-2">Manage process documents and KB sources for KnowledgeBased parameter evaluation.</p>
                    <a href="@Url.Action("Index", "KnowledgeBase")" class="btn btn-outline-success btn-sm w-100">
                        <i class="bi bi-folder2-open me-1"></i>Manage Knowledge Base
                    </a>
                </div>
            </div>
            <button type="submit" class="btn btn-primary w-100 btn-lg">
                <i class="bi bi-save me-2"></i>Save Settings
            </button>
            <div class="text-muted small text-center mt-2">Settings are saved to the database immediately.</div>
        </div>
    </div>
</form>

@section Scripts {
<script>
    function toggleLangFields() {
        const p = document.getElementById('sentimentProvider').value;
        document.getElementById('langFields').style.display = p === 'AzureLanguage' ? '' : 'none';
    }
    function toggleLlmFields() {
        const p = document.getElementById('llmProvider').value;
        const isGoogle = p === 'Google';
        document.getElementById('llmEndpointField').style.display  = isGoogle ? 'none' : '';
        document.getElementById('llmApiKeyField').style.display    = isGoogle ? 'none' : '';
        document.getElementById('llmDeploymentField').style.display = isGoogle ? 'none' : '';
    }
    function toggleSpeechFields() {
        const p = document.getElementById('speechProvider').value;
        const isGoogle = p === 'Google';
        document.getElementById('speechEndpointField').style.display = isGoogle ? 'none' : '';
        document.getElementById('speechApiKeyField').style.display   = isGoogle ? 'none' : '';
        document.getElementById('googleSttNote').style.display       = isGoogle ? '' : 'none';
    }
</script>
}
