@model List<EvaluationFormViewModel>
@{
    ViewData["Title"] = "Form Designer";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-layout-text-window me-2 text-info"></i>Evaluation Forms</h4>
        <p class="text-muted mb-0">Create and manage QA evaluation forms using a 3-level designer.</p>
    </div>
    <a href="/FormDesigner/Designer" class="btn btn-info text-white">
        <i class="bi bi-plus-lg me-1"></i>New Form
    </a>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-layout-text-window fs-1 d-block mb-2"></i>
                No evaluation forms yet. <a href="/FormDesigner/Designer">Create the first one.</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Sections</th>
                            <th>Status</th>
                            <th>Updated</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var f in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@f.Name</td>
                                <td class="text-muted small">@(f.Description ?? "-")</td>
                                <td><span class="badge bg-info text-dark rounded-pill">@f.Sections.Count</span></td>
                                <td>
                                    <span class="badge @(f.IsActive ? "bg-success" : "bg-warning text-dark")">
                                        @(f.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="text-muted small">@f.UpdatedAt.ToString("MMM d, yyyy")</td>
                                <td class="text-end">
                                    <a href="/FormDesigner/Designer/@f.Id" class="btn btn-sm btn-outline-info me-1">
                                        <i class="bi bi-pencil-square me-1"></i>Edit
                                    </a>
                                    <form method="post" action="/FormDesigner/Delete/@f.Id" class="d-inline"
                                          onsubmit="return confirm('Delete form @f.Name?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
