@model List<ParameterViewModel>
@{
    ViewData["Title"] = "Parameters";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-sliders me-2 text-primary"></i>Parameters</h4>
        <p class="text-muted mb-0">Individual evaluation criteria used in parameter clubs.</p>
    </div>
    <a href="/Parameters/Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Parameter
    </a>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-sliders fs-1 d-block mb-2"></i>
                No parameters found. <a href="/Parameters/Create">Add the first parameter.</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Evaluation Type</th>
                            <th>Weight</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@p.Name</div>
                                    @if (!string.IsNullOrEmpty(p.Description))
                                    {
                                        <div class="text-muted small">@p.Description</div>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(p.Category))
                                    {
                                        <span class="badge bg-light text-dark border">@p.Category</span>
                                    }
                                    else { <span class="text-muted">-</span> }
                                </td>
                                <td>
                                    @if (p.EvaluationType == "KnowledgeBased")
                                    {
                                        <span class="badge bg-success" title="Scored using RAG context from Knowledge Base"><i class="bi bi-database me-1"></i>Knowledge Based</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary" title="Scored directly by LLM"><i class="bi bi-cpu me-1"></i>LLM / Soft Skill</span>
                                    }
                                </td>
                                <td><span class="badge bg-info text-dark">@p.DefaultWeight.ToString("F1")</span></td>
                                <td>
                                    <span class="badge @(p.IsActive ? "bg-success" : "bg-warning text-dark")">
                                        @(p.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a href="/Parameters/Edit/@p.Id" class="btn btn-sm btn-outline-secondary me-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="/Parameters/Delete/@p.Id" class="d-inline"
                                          onsubmit="return confirm('Delete parameter @p.Name?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
