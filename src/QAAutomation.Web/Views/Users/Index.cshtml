@model List<UserViewModel>
@{
    ViewData["Title"] = L["PageTitleUsers"].Value;
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-people me-2 text-primary"></i>@L["UsersTitle"]</h4>
        <p class="text-muted mb-0">Manage system users and their roles.</p>
    </div>
    <a href="@Url.Action("Create", "Users")" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>@L["UsersCreate"]
    </a>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-people fs-1 d-block mb-2"></i>
                No users found. <a href="@Url.Action("Create", "Users")">Add the first user.</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>@L["LblUsername"]</th>
                            <th>Email</th>
                            <th>@L["LblRole"]</th>
                            <th>@L["LblStatus"]</th>
                            <th>@L["LblCreatedAt"]</th>
                            <th class="text-end">@L["LblActions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td class="fw-semibold">
                                    <i class="bi bi-person-circle me-1 text-muted"></i>@u.Username
                                </td>
                                <td class="text-muted">@(u.Email ?? "-")</td>
                                <td>
                                    <span class="badge @(u.Role == "Admin" ? "bg-danger" : "bg-secondary")">@u.Role</span>
                                </td>
                                <td>
                                    <span class="badge @(u.IsActive ? "bg-success" : "bg-warning text-dark")">
                                        @(u.IsActive ? L["LblActive"].Value : L["LblInactive"].Value)
                                    </span>
                                </td>
                                <td class="text-muted small">@u.CreatedAt.ToString("MMM d, yyyy")</td>
                                <td class="text-end">
                                    <a href="@Url.Action("Edit", "Users", new { id = u.Id })" class="btn btn-sm btn-outline-secondary me-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="@Url.Action("Delete", "Users", new { id = u.Id })" class="d-inline"
                                          onsubmit="return confirm('Delete user @u.Username?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
