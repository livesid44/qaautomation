@model CreateUserViewModel
@{
    ViewData["Title"] = L["UsersCreate"].Value;
}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4">
                <h5 class="fw-bold mb-0"><i class="bi bi-person-plus me-2 text-primary"></i>@L["UsersCreate"]</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" asp-controller="Users" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="Username" class="form-label fw-semibold">@L["LblUsername"] <span class="text-danger">*</span></label>
                        <input asp-for="Username" class="form-control" placeholder="@L["LoginEnterUsername"]" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold">@L["LblPassword"] <span class="text-danger">*</span></label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="@L["LoginEnterPassword"]" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">@L["LblEmail"]</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="@L["LblEmail"]" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Role" class="form-label fw-semibold">@L["LblRole"]</label>
                        <select asp-for="Role" class="form-select">
                            <option value="User">@L["UsersUserRole"]</option>
                            <option value="Admin">@L["UsersAdminRole"]</option>
                        </select>
                    </div>
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
                    {
                        <div class="alert alert-danger py-2">
                            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@err.ErrorMessage</div>
                            }
                        </div>
                    }
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>@L["UsersCreate"]
                        </button>
                        <a href="@Url.Action("Index", "Users")" class="btn btn-outline-secondary">@L["BtnCancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
