@model ProjectViewModel
@{
    ViewData["Title"] = L["BtnEdit"].Value + " — " + Model.Name;
    var projectUsers = ViewData["ProjectUsers"] as List<ProjectUserViewModel> ?? new();
    var allUsers = ViewData["AllUsers"] as List<UserViewModel> ?? new();
    var assignedIds = projectUsers.Select(u => u.Id).ToHashSet();
    var unassignedUsers = allUsers.Where(u => !assignedIds.Contains(u.Id) && u.IsActive).ToList();
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-0"><i class="bi bi-building me-2 text-primary"></i>@Model.Name</h5>
        <small class="text-muted">Project ID: @Model.Id · <a href="@Url.Action("Index", "Lobs", new { projectId = Model.Id })">Manage LOBs</a></small>
    </div>
    <a href="@Url.Action("Index", "Projects")" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>@L["NavProjects"]</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible py-2"><button type="button" class="btn-close" data-bs-dismiss="alert"></button>@TempData["Success"]</div>
}

<div class="row g-4">
    <!-- Project settings -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-gear me-2 text-secondary"></i>@L["LblDetails"]</h6>
            </div>
            <div class="card-body">
                <form method="post" action="@Url.Action("Edit", "Projects", new { id = Model.Id })">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">@L["LblName"] *</label>
                        <input name="name" class="form-control" value="@Model.Name" required maxlength="200" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">@L["LblDescription"]</label>
                        <textarea name="description" class="form-control" rows="2">@Model.Description</textarea>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" name="isActive" value="true" class="form-check-input" id="isActive"
                               @(Model.IsActive ? "checked" : "") />
                        <input type="hidden" name="isActive" value="false" />
                        <label for="isActive" class="form-check-label small">@L["LblActive"]</label>
                    </div>
                    <hr class="my-3" />
                    <div class="mb-2">
                        <div class="fw-semibold small mb-1"><i class="bi bi-shield-lock me-1 text-danger"></i>PII / SPII Protection</div>
                        <div class="text-muted" style="font-size:.75rem">When enabled, call transcripts are scanned for personally identifiable information before being sent to the LLM.</div>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" name="piiProtectionEnabled" value="true" class="form-check-input" id="piiProtectionEnabled"
                               @(Model.PiiProtectionEnabled ? "checked" : "") onchange="togglePiiMode(this)" />
                        <input type="hidden" name="piiProtectionEnabled" value="false" />
                        <label for="piiProtectionEnabled" class="form-check-label small fw-semibold">Enable PII/SPII protection for this project</label>
                    </div>
                    <div class="mb-3" id="piiModeSection" style="@(Model.PiiProtectionEnabled ? "" : "display:none")">
                        <label class="form-label fw-semibold small">Protection Mode</label>
                        <select name="piiRedactionMode" class="form-select form-select-sm" style="max-width:260px">
                            @if (Model.PiiRedactionMode == "Block") {
                                <option value="Redact">Redact — replace PII with placeholders</option>
                                <option value="Block" selected>Block  — reject audit if PII detected</option>
                            } else {
                                <option value="Redact" selected>Redact — replace PII with placeholders</option>
                                <option value="Block">Block  — reject audit if PII detected</option>
                            }
                        </select>
                        <div class="form-text">
                            <strong>Redact</strong>: tokens like emails, phone numbers, SSNs are replaced with <code>[EMAIL]</code>, <code>[PHONE]</code>, etc. before the transcript reaches the AI.<br />
                            <strong>Block</strong>: the AI audit is refused entirely when sensitive data is detected.
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-check2 me-1"></i>Save</button>
                </form>
            </div>
        </div>

        <!-- LOBs quick link -->
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body py-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="fw-semibold small">Lines of Business</div>
                        <div class="text-muted small">@Model.LobCount LOB@(Model.LobCount != 1 ? "s" : "") in this project</div>
                    </div>
                    <a href="@Url.Action("Index", "Lobs", new { projectId = Model.Id })" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-layers me-1"></i>Manage LOBs
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- User access -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-people me-2 text-secondary"></i>User Access</h6>
                <div class="text-muted small">Admin users have implicit access to all projects. Manage access for non-admin users here.</div>
            </div>
            <div class="card-body">
                @if (projectUsers.Any())
                {
                    <table class="table table-sm mb-3">
                        <thead class="table-light">
                            <tr><th>User</th><th>Role</th><th>Granted</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var u in projectUsers)
                            {
                                <tr>
                                    <td><i class="bi bi-person-circle me-1 text-muted"></i>@u.Username</td>
                                    <td><span class="badge bg-secondary">@u.Role</span></td>
                                    <td class="text-muted small">@u.GrantedAt.ToString("MMM d, yyyy")</td>
                                    <td>
                                        <form method="post" action="@Url.Action("RevokeAccess", "Projects")" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@Model.Id" />
                                            <input type="hidden" name="userId" value="@u.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Remove @u.Username from this project?')">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted small">No non-admin users assigned yet.</p>
                }

                @if (unassignedUsers.Any())
                {
                    <form method="post" action="@Url.Action("GrantAccess", "Projects")" class="d-flex gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <select name="userId" class="form-select form-select-sm">
                            @foreach (var u in unassignedUsers)
                            {
                                <option value="@u.Id">@u.Username (@u.Role)</option>
                            }
                        </select>
                        <button type="submit" class="btn btn-sm btn-success flex-shrink-0">
                            <i class="bi bi-person-plus me-1"></i>Grant Access
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function togglePiiMode(cb) {
        document.getElementById('piiModeSection').style.display = cb.checked ? '' : 'none';
    }
</script>
}
