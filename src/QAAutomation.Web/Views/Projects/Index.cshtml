@model List<ProjectViewModel>
@{
    ViewData["Title"] = L["PageTitleProjects"].Value;
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-building me-2 text-primary"></i>@L["ProjectsTitle"]</h4>
        <p class="text-muted mb-0">Top-level tenants. Each project contains Lines of Business and their Evaluation Forms.</p>
    </div>
    <a href="@Url.Action("Create", "Projects")" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>@L["ProjectsCreate"]
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible"><button type="button" class="btn-close" data-bs-dismiss="alert"></button>@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible"><button type="button" class="btn-close" data-bs-dismiss="alert"></button>@TempData["Error"]</div>
}

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-building fs-1 d-block mb-2"></i>
            No projects yet. <a href="@Url.Action("Create", "Projects")">Create the first project</a>.
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var project in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-start gap-3 mb-2">
                            <div class="rounded-circle bg-primary bg-opacity-10 p-2">
                                <i class="bi bi-building text-primary"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="fw-bold mb-0">@project.Name</h6>
                                @if (!project.IsActive)
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(project.Description))
                        {
                            <p class="text-muted small mb-2">@project.Description</p>
                        }
                        <div class="text-muted small mb-3">
                            <i class="bi bi-layers me-1"></i>@project.LobCount LOB@(project.LobCount != 1 ? "s" : "")
                            <span class="ms-2 text-muted">Created @project.CreatedAt.ToString("MMM yyyy")</span>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="@Url.Action("Edit", "Projects", new { id = project.Id })" class="btn btn-sm btn-outline-secondary flex-grow-1">
                                <i class="bi bi-pencil me-1"></i>Edit / Users
                            </a>
                            <a href="@Url.Action("Index", "Lobs", new { projectId = project.Id })" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-layers"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
