@model AutoAuditUploadViewModel
@{
    ViewData["Title"] = "Auto Audit — Upload Transcript";
    var forms = ViewBag.Forms as List<LegacyFormViewModel> ?? new List<LegacyFormViewModel>();
}
@section Styles {
<style>
    .upload-zone {
        border: 2px dashed #dee2e6;
        border-radius: 12px;
        padding: 32px;
        text-align: center;
        cursor: pointer;
        transition: border-color .2s, background .2s;
        background: #fafbfc;
    }
    .upload-zone:hover, .upload-zone.drag-over {
        border-color: #0d6efd;
        background: #f0f6ff;
    }
    .upload-zone .upload-icon { font-size: 2.5rem; color: #adb5bd; }
    .or-divider {
        display: flex; align-items: center; gap: 12px;
        color: #adb5bd; font-size: .85rem; margin: 16px 0;
    }
    .or-divider::before, .or-divider::after {
        content: ""; flex: 1; height: 1px; background: #dee2e6;
    }
    .badge-ai { background: linear-gradient(135deg,#667eea,#764ba2); color:#fff; }
</style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-robot me-2 text-primary"></i>Auto Audit
            <span class="badge badge-ai ms-2 fs-6">AI Powered</span>
        </h4>
        <p class="text-muted mb-0">Upload a call transcript and let @(ViewData["LlmDisplayName"] as string ?? "AI") score it automatically against your QA form.</p>
    </div>
    <a href="@Url.Action("Index", "Audit")" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Audits
    </a>
</div>

@if (ViewData.ModelState != null && !ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div><i class="bi bi-exclamation-triangle me-1"></i>@err.ErrorMessage</div>
        }
    </div>
}

<form method="post" action="@Url.Action("Upload", "AutoAudit")" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="row g-4">
        <div class="col-lg-7">
            <!-- Transcript input -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-file-text me-2 text-primary"></i>Call Transcript</h6>
                    <p class="text-muted small mb-0">Upload a .txt file or paste the transcript text below.</p>
                </div>
                <div class="card-body">
                    <!-- File upload zone -->
                    <div class="upload-zone" id="uploadZone" onclick="document.getElementById('transcriptFile').click()">
                        <div class="upload-icon mb-2"><i class="bi bi-cloud-arrow-up"></i></div>
                        <div class="fw-semibold mb-1">Drop a transcript file here or click to browse</div>
                        <div class="text-muted small">.txt files supported · max 500 KB</div>
                        <div id="fileNameDisplay" class="mt-2 text-primary small" style="display:none"></div>
                    </div>
                    <input type="file" id="transcriptFile" name="transcriptFile" accept=".txt,text/plain"
                           class="d-none" onchange="handleFileSelect(this)" />

                    <div class="or-divider">OR paste transcript</div>

                    <textarea name="TranscriptText" id="transcriptText" class="form-control"
                              rows="12" placeholder="Paste the full call transcript here...

Example:
Agent: Thank you for calling Capital One, this is Sarah. How can I help you today?
Customer: Hi, I need to dispute a charge on my credit card...
Agent: I'd be happy to help with that. For security, could you please verify the last four digits of your Social Security Number?
...">@Model.TranscriptText</textarea>
                    <div class="d-flex justify-content-between mt-1">
                        <span class="text-muted small" id="charCount">0 characters</span>
                        <span class="text-muted small">Max 12,000 characters (longer transcripts are truncated)</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <!-- Audit settings -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="fw-bold mb-0"><i class="bi bi-gear me-2 text-secondary"></i>Audit Settings</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Evaluation Form <span class="text-danger">*</span></label>
                        <select name="FormId" class="form-select" required>
                            <option value="">— Select form —</option>
                            @foreach (var f in forms)
                            {
                                if (f.Id == Model.FormId)
                                {
                                    <option value="@f.Id" selected>@f.Name</option>
                                }
                                else
                                {
                                    <option value="@f.Id">@f.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Agent Name</label>
                        <input type="text" name="AgentName" class="form-control"
                               placeholder="Leave blank — AI will try to detect"
                               value="@Model.AgentName" />
                        <div class="form-text">The AI will extract the agent name from the transcript if not provided.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Evaluated By <span class="text-danger">*</span></label>
                        <input type="text" name="EvaluatedBy" class="form-control" required
                               value="@Model.EvaluatedBy" />
                    </div>
                    <div class="row g-2">
                        <div class="col-7">
                            <label class="form-label fw-semibold">Call Reference</label>
                            <input type="text" name="CallReference" class="form-control"
                                   placeholder="CALL-2026-00001"
                                   value="@Model.CallReference" />
                        </div>
                        <div class="col-5">
                            <label class="form-label fw-semibold">Call Date</label>
                            <input type="date" name="CallDate" class="form-control"
                                   value="@(Model.CallDate.HasValue ? Model.CallDate.Value.ToString("yyyy-MM-dd") : "")" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- How it works -->
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle me-2 text-info"></i>How it works</h6>
                    <div class="d-flex gap-2 mb-2">
                        <span class="badge bg-primary rounded-circle" style="width:22px;height:22px;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0">1</span>
                        <span class="small">Upload or paste the call transcript</span>
                    </div>
                    <div class="d-flex gap-2 mb-2">
                        <span class="badge bg-primary rounded-circle" style="width:22px;height:22px;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0">2</span>
                        <span class="small">@(ViewData["LlmDisplayName"] as string ?? "AI") reads the transcript and scores each QA parameter with evidence-based reasoning</span>
                    </div>
                    <div class="d-flex gap-2 mb-2">
                        <span class="badge bg-primary rounded-circle" style="width:22px;height:22px;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0">3</span>
                        <span class="small">Review the AI-suggested scores, adjust if needed, then save</span>
                    </div>
                    <hr class="my-3" />
                    <div class="small text-muted">
                        <i class="bi bi-shield-check me-1 text-success"></i>
                        Transcript content is only sent to your configured @(ViewData["LlmDisplayName"] as string ?? "AI") endpoint and is not stored externally.
                    </div>
                </div>
            </div>

            <div class="d-grid mt-4">
                <button type="submit" class="btn btn-primary btn-lg" id="analyzeBtn">
                    <i class="bi bi-cpu me-2"></i>Analyze with AI
                </button>
            </div>
            <div id="analyzingMsg" class="text-center text-muted mt-3" style="display:none">
                <div class="spinner-border spinner-border-sm me-2"></div>
                Analyzing transcript — this may take a few seconds...
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
    const textarea = document.getElementById('transcriptText');
    const charCount = document.getElementById('charCount');

    function updateCharCount() {
        const len = textarea.value.length;
        charCount.textContent = len.toLocaleString() + ' characters';
        charCount.className = 'small ' + (len > 12000 ? 'text-warning' : 'text-muted');
    }
    textarea.addEventListener('input', updateCharCount);
    updateCharCount();

    function handleFileSelect(input) {
        const file = input.files[0];
        if (!file) return;
        if (file.size > 512000) {
            alert('File too large. Maximum size is 500 KB.');
            input.value = '';
            return;
        }
        const display = document.getElementById('fileNameDisplay');
        display.textContent = '📎 ' + file.name + ' (' + (file.size / 1024).toFixed(1) + ' KB)';
        display.style.display = 'block';
        // Clear pasted text when file is selected
        textarea.value = '';
        updateCharCount();
    }

    // Drag & drop
    const zone = document.getElementById('uploadZone');
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => {
        e.preventDefault();
        zone.classList.remove('drag-over');
        const file = e.dataTransfer.files[0];
        if (file) {
            const input = document.getElementById('transcriptFile');
            const dt = new DataTransfer();
            dt.items.add(file);
            input.files = dt.files;
            handleFileSelect(input);
        }
    });

    // Show loading state on submit
    document.querySelector('form').addEventListener('submit', function() {
        document.getElementById('analyzeBtn').disabled = true;
        document.getElementById('analyzingMsg').style.display = 'block';
    });
</script>
}
