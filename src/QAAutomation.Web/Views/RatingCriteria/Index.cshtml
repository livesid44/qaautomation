@model List<RatingCriteriaViewModel>
@{
    ViewData["Title"] = "Rating Criteria";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-star-half me-2 text-warning"></i>Rating Criteria</h4>
        <p class="text-muted mb-0">Define rating scales used to evaluate parameters.</p>
    </div>
    <a href="@Url.Action("Designer", "RatingCriteria")" class="btn btn-warning text-dark">
        <i class="bi bi-plus-lg me-1"></i>New Criteria
    </a>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-star-half fs-1 d-block mb-2"></i>
                No rating criteria yet. <a href="@Url.Action("Designer", "RatingCriteria")">Create the first one.</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Scale</th>
                            <th>Levels</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@c.Name</div>
                                    @if (!string.IsNullOrEmpty(c.Description))
                                    {
                                        <div class="text-muted small">@c.Description</div>
                                    }
                                </td>
                                <td><span class="badge bg-secondary">@c.MinScore – @c.MaxScore</span></td>
                                <td>
                                    @if (c.Levels.Any())
                                    {
                                        @foreach (var l in c.Levels.Take(5))
                                        {
                                            <span class="badge me-1" style="background-color:@l.Color">@l.Label</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No levels</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @(c.IsActive ? "bg-success" : "bg-warning text-dark")">
                                        @(c.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a href="@Url.Action("Designer", "RatingCriteria", new { id = c.Id })" class="btn btn-sm btn-outline-warning me-1">
                                        <i class="bi bi-pencil-square me-1"></i>Edit
                                    </a>
                                    <form method="post" action="@Url.Action("Delete", "RatingCriteria", new { id = c.Id })" class="d-inline"
                                          onsubmit="return confirm('Delete criteria @c.Name?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
